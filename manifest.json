{
  "manifest_version": 3,
  "name": "YouTube Live Chat Summarizer",
  "version": "1.0.1",
  "description": "Real-time YouTube Live chat and replay summarization using Gemini AI. Supports 75+ languages with smart API quota saving.",
  "author": "Kimiya Kitani",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "sidePanel",
    "storage"
  ],
  "host_permissions": [
    "https://*.google.com/*",
    "https://*.youtube.com/*",
    "https://generativelanguage.googleapis.com/*"
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/live_chat*",
        "https://www.youtube.com/live_chat_replay*"
      ],
      "js": [
        "content.js"
      ],
      "all_frames": true,
      "run_at": "document_end"
    }
  ]
}